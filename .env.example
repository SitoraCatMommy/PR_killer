# Application
APP_NAME=research-intelligence-agent
APP_ENV=local
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=*

# Server (uvicorn)
HOST=0.0.0.0
PORT=8000

# PostgreSQL (async URL for app; sync URL for Alembic)
DATABASE_URL=postgresql+asyncpg://ria:ria@localhost:5432/research_intel
DATABASE_URL_SYNC=postgresql+psycopg://ria:ria@localhost:5432/research_intel

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Embeddings / dedup (OpenAI-compatible dimension; adjust to your model)
EMBEDDING_DIMENSION=1536

# Local file storage root (Docker: mount at /data/uploads)
UPLOAD_STORAGE_PATH=/data/uploads
# Maximum upload size accepted by API routes (100 MiB default)
UPLOAD_MAX_BYTES=104857600
# Maximum files accepted by one bulk upload request
UPLOAD_MAX_FILES=50

# Research entity extraction: `mock` (rules) or `gpt` (OpenAI; falls back to mock if no key)
RESEARCH_EXTRACTION_PROVIDER=gpt
# Summary: `deterministic` (bucket entities) or `gpt` (OpenAI; falls back if no key)
RESEARCH_SUMMARY_PROVIDER=gpt
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# PR report flow safeguards. Report generation will not spend final-report tokens
# until enough PR-synthesis signals exist, and auto-extraction from the report
# button is capped to avoid unexpectedly large GPT extraction runs.
PR_REPORT_MIN_SYNTHESIS_ENTITIES=3
PR_REPORT_MAX_AUTO_EXTRACT_CHUNKS=40
PR_REPORT_AUTO_PREPARE=true
PR_REPORT_MAX_PROMPT_CHARS=45000
PR_REPORT_MAX_REPAIR_ATTEMPTS=1

# Text chunking for documents & transcripts (sync Celery orchestrator)
CHUNK_MAX_CHARS=500
CHUNK_OVERLAP_CHARS=80

# OpenAI — semantic chunking (`/chunk/semantic` и аналоги для транскриптов).
# Локально: Pydantic читает этот файл (env_file=.env в Settings).
# Docker: `docker-compose.yml` подключает `.env` к api и worker (env_file), плюс переменные ниже переопределяют БД/Redis под контейнеры.
OPENAI_API_KEY=
OPENAI_SEMANTIC_CHUNK_MODEL=gpt-4o-mini
OPENAI_SEMANTIC_CHUNK_WINDOW_CHARS=24000

# Research audio transcription: mock | openai | whisper_local | http
RESEARCH_TRANSCRIPTION_PROVIDER=mock
# RESEARCH_TRANSCRIPTION_FALLBACK_TO_MOCK=false
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_TIMEOUT_SECONDS=300
# Local Whisper CLI (requires `whisper` on PATH and file on disk in worker)
# WHISPER_LOCAL_COMMAND=whisper
# WHISPER_LOCAL_MODEL=base
# WHISPER_LOCAL_TIMEOUT_SECONDS=3600
# Custom HTTP ASR when RESEARCH_TRANSCRIPTION_PROVIDER=http
# TRANSCRIPTION_API_URL=
# TRANSCRIPTION_API_KEY=
